@model List<LibraryOS.Models.PhieuMuonRow>
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"]      = "Phiếu mượn";
    ViewData["ActiveMenu"] = "phieumuon";
    var tinhTrang = ViewBag.TinhTrang as string ?? "";
}

<div class="panel full">
    <div class="ph">
        <div>
            <div class="pt">Danh sách phiếu mượn</div>
            <div class="ps">Tổng: @Model.Count phiếu</div>
        </div>
        <a asp-action="TaoPhieuMuon" class="btn b-teal btn-sm">+ Tạo phiếu mượn</a>
    </div>
    <div class="tsearch">
        <input id="search-input" placeholder="Tìm mã PM, tên độc giả, số thẻ..." oninput="locBang(this.value)">
        <select onchange="window.location.href='/ThuThu/PhieuMuon?tinhTrang='+this.value">
            <option value="">Tất cả trạng thái</option>
            <option value="Đang mượn">Đang mượn</option>
            <option value="Đã trả">Đã trả</option>
            <option value="Quá hạn">Quá hạn</option>
        </select>
    </div>

    @if (!Model.Any())
    {
        <div class="empty">
            <div class="empty-icon">📭</div>
            Không có phiếu mượn nào
        </div>
    }
    else
    {
        <table id="bang-phieu">
            <thead>
                <tr>
                    <th>Mã PM</th>
                    <th>Thẻ TV</th>
                    <th>Độc giả</th>
                    <th>NV lập</th>
                    <th>Ngày mượn</th>
                    <th>Số cuốn</th>
                    <th>Trạng thái</th>
                    <th>Hành động</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var pm in Model)
                {
                    var pillCls = pm.TinhTrang switch {
                        "Đang mượn" => "p-blue",
                        "Đã trả"    => "p-teal",
                        "Quá hạn"   => "p-rose",
                        _           => "p-muted"
                    };
                    <tr data-mapm="@pm.MaPM">
                        <td class="mo">@pm.MaPM</td>
                        <td class="mo">@pm.SoTheTV</td>
                        <td>@pm.HoTenDG</td>
                        <td style="color:var(--txt-secondary);font-size:11px">@pm.TenNV</td>
                        <td class="mo">@pm.NgayMuon</td>
                        <td style="font-family:var(--mono)">@pm.SoCuon cuốn</td>
                        <td><span class="pill @pillCls">@pm.TinhTrang</span></td>
                        <td>
                            @if (pm.TinhTrang == "Đang mượn")
                            {
                                <button class="btn b-ghost btn-sm"
                                        onclick="xacNhanTra('@pm.MaPM')">
                                    Xác nhận trả
                                </button>
                            }
                            else if (pm.TinhTrang == "Quá hạn")
                            {
                                @if (pm.DaCoPhieuPhat > 0)
                                {
                                    <span class="pill p-amber">Đã lập phạt</span>
                                }
                                else
                                {
                                    <button class="btn b-ghost btn-sm"
                                            style="color:#f5a623;border-color:#f5a62333"
                                            onclick="chuyenLapPhat('@pm.MaPM')">
                                        Lập phạt
                                    </button>
                                }
                            }
                            else
                            {
                                <span style="color:var(--txt-muted);font-size:11px">—</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>

@section Scripts {
<script>
function locBang(kw) {
    kw = kw.toLowerCase();
    document.querySelectorAll('#bang-phieu tbody tr').forEach(tr => {
        const text = tr.innerText.toLowerCase();
        tr.style.display = text.includes(kw) ? '' : 'none';
    });
}
        // ── Tìm kiếm ────────────────────────────────────
        function locBang(kw) {
            kw = kw.toLowerCase();
            document.querySelectorAll('#bang-phieu tbody tr').forEach(tr =>
                tr.style.display = tr.innerText.toLowerCase().includes(kw) ? '' : 'none');
        }

        // ── Xác nhận trả sách ───────────────────────────
        async function xacNhanTra(maPM) {
            if (!confirm(`Xác nhận trả sách cho phiếu ${maPM}?\nThao tác này sẽ cập nhật trạng thái sách về kho.`))
                return;

            const controller = window.location.pathname.includes('QuanLy') ? 'QuanLy' : 'ThuThu';

            const res  = await fetch(`/${controller}/TraSach`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: `maPM=${encodeURIComponent(maPM)}`
            });
            const data = await res.json();

            if (data.ok) {
                // Cập nhật UI ngay không cần reload
                const row = document.querySelector(`tr[data-mapm="${maPM}"]`);
                if (row) {
                    // Đổi pill trạng thái
                    const pill = row.querySelector('.pill');
                    if (pill) {
                        pill.className = 'pill p-teal';
                        pill.textContent = 'Đã trả';
                    }
                    // Ẩn nút
                    const btn = row.querySelector('button');
                    if (btn) btn.outerHTML = '<span style="color:var(--txt-muted);font-size:11px">—</span>';
                }
                alert('✅ ' + data.msg);
                window.location.reload();
            } else {
                alert('❌ ' + data.msg);
            }
        }
                function chuyenLapPhat(maPM) {
            const controller = window.location.pathname.includes('QuanLy') ? 'QuanLy' : 'ThuThu';
            window.location.href = `/${controller}/PhieuPhat?maPM=${maPM}`;
        }
        async function lapPhat(maPM) {
            alert('Chức năng lập phạt cho ' + maPM + ' đang phát triển...');
        }
</script>
}