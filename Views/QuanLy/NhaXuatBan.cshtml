@model List<LibraryOS.Models.NhaXuatBanRow>
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Nhà xuất bản";
    ViewData["ActiveMenu"] = "nxb";
    var kw = ViewBag.Keyword as string ?? "";
}

<div class="panel full">
    <div class="ph">
        <div>
            <div class="pt">Danh sách nhà xuất bản</div>
            <div class="ps">NHAXUATBAN table · @Model.Count NXB</div>
        </div>
        <button class="btn b-blue btn-sm" onclick="moModal()">+ Thêm NXB</button>
    </div>
    <form method="get" asp-action="NhaXuatBan">
        <div class="tsearch">
            <input name="kw" value="@kw" placeholder="Tìm tên NXB, người đại diện...">
            <button type="submit" class="btn b-ghost btn-sm">Tìm</button>
        </div>
    </form>

    @if (!Model.Any())
    {
        <div class="empty"><div class="empty-icon">🏢</div>Không tìm thấy nhà xuất bản nào</div>
    }
    else
    {
        <table>
            <thead>
                <tr><th>Mã NXB</th><th>Tên nhà xuất bản</th><th>Người đại diện</th><th>Email</th><th>Địa chỉ</th><th>Số sách</th><th></th></tr>
            </thead>
            <tbody>
                @foreach (var n in Model)
                {
                    <tr>
                        <td class="mo" style="color:#a78bfa">@n.MaNXB</td>
                        <td style="font-weight:500">@n.TenNXB</td>
                        <td>@n.NguoiDaiDien</td>
                        <td style="font-size:12px;color:var(--accent-blue)">@n.EmailNXB</td>
                        <td style="font-size:12px;color:var(--txt-secondary)">@n.DiaChiNXB</td>
                        <td><span class="pill @(n.SoSach > 0 ? "p-teal" : "p-muted")">@n.SoSach đầu sách</span></td>
                        <td style="display:flex;gap:6px">
                            <button class="btn b-ghost btn-sm">Sửa</button>
                            <button class="btn b-ghost btn-sm" style="color:#f06292">Xóa</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>

<div id="modal-overlay" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.6);z-index:999;align-items:center;justify-content:center">
    <div style="background:var(--bg-surface);border:1px solid var(--border-md);border-radius:var(--r-lg);width:480px;overflow:hidden">
        <div class="ph">
            <div class="pt">Thêm nhà xuất bản</div>
            <button onclick="dongModal()" style="background:none;border:none;color:var(--txt-muted);cursor:pointer;font-size:18px">✕</button>
        </div>
        <div style="padding:20px 24px;display:grid;grid-template-columns:1fr 1fr;gap:14px">
            <div style="display:flex;flex-direction:column;gap:6px">
                <label class="flbl">Mã NXB</label>
                <input class="finp" placeholder="VD: NXB006">
            </div>
            <div style="display:flex;flex-direction:column;gap:6px">
                <label class="flbl">Người đại diện</label>
                <input class="finp" placeholder="Họ và tên">
            </div>
            <div style="display:flex;flex-direction:column;gap:6px;grid-column:1/-1">
                <label class="flbl">Tên nhà xuất bản</label>
                <input class="finp" placeholder="Tên đầy đủ">
            </div>
            <div style="display:flex;flex-direction:column;gap:6px">
                <label class="flbl">Email</label>
                <input class="finp" placeholder="email@nxb.vn">
            </div>
            <div style="display:flex;flex-direction:column;gap:6px;grid-column:1/-1">
                <label class="flbl">Địa chỉ</label>
                <input class="finp" placeholder="Địa chỉ NXB">
            </div>
            <div style="display:flex;gap:10px;justify-content:flex-end;grid-column:1/-1;margin-top:4px">
                <button onclick="dongModal()" class="btn b-ghost">Hủy</button>
                <button class="btn b-blue">Lưu</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function moModal()  { document.getElementById('modal-overlay').style.display = 'flex'; }
        function dongModal(){ document.getElementById('modal-overlay').style.display = 'none'; }
    </script>
}