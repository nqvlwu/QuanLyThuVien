@model LibraryOS.Models.DocGiaDashboardVM
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Trang chủ";
    ViewData["ActiveMenu"] = "dashboard";
}

<div class="welcome-card">
    <div>
        <div style="font-size:10px;font-family:var(--mono);color:var(--txt-muted);margin-bottom:6px">XIN CHÀO, ĐỌC GIẢ</div>
        <div style="font-size:20px;font-weight:600">@Model.HoTen</div>
        <div style="font-size:11px;font-family:var(--mono);color:var(--txt-muted);margin-top:8px">
            Số thẻ: <span style="color:#f06292">@Model.SoTheTV</span>
        </div>
        @if (Model.ConHan)
        {
            <span class="wc-valid">✓ Thẻ còn hạn đến @Model.NgayHetHan</span>
        }
        else
        {
            <span class="pill p-rose" style="margin-top:7px">✗ Thẻ đã hết hạn</span>
        }
    </div>
    <div style="text-align:right">
        <div style="font-size:10px;color:var(--txt-muted);font-family:var(--mono);margin-bottom:4px">ĐANG MƯỢN</div>
        <div style="font-size:44px;font-weight:600;color:#f06292;font-family:var(--mono);line-height:1">@Model.SoSachDangMuon</div>
        <div style="font-size:11px;color:var(--txt-secondary)">/ tối đa 5 cuốn</div>
    </div>
</div>

<div class="pgrid">
    <div class="panel">
        <div class="ph">
            <div class="pt">Sách đang mượn</div>
        </div>
        @if (!Model.SachDangMuon.Any())
        {
            <div class="empty"><div class="empty-icon">📭</div>Bạn chưa mượn sách nào</div>
        }
        else
        {
            <table>
                <thead><tr><th>Tên sách</th><th>Mã cuốn</th><th>Ngày mượn</th><th>Hạn trả</th><th>Còn lại</th></tr></thead>
                <tbody>
                    @foreach (var s in Model.SachDangMuon)
                    {
                        <tr>
                            <td style="font-weight:500">@s.TenSach</td>
                            <td class="mo">@s.MaCuonSach</td>
                            <td class="mo">@s.NgayMuon</td>
                            <td class="mo" style="@(s.NgayConLai < 3 ? "color:#f06292" : "")">@s.NgayTra</td>
                            <td style="font-family:var(--mono);color:@(s.NgayConLai < 3 ? "#f06292" : "#2dd4a6")">
                                @(s.NgayConLai < 0 ? "Quá hạn" : s.NgayConLai + " ngày")
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>

    <div class="panel">
        <div class="ph"><div class="pt">Lịch sử mượn</div></div>
        @if (!Model.LichSuMuon.Any())
        {
            <div class="empty"><div class="empty-icon">📋</div>Chưa có lịch sử mượn</div>
        }
        else
        {
            @foreach (var ls in Model.LichSuMuon)
            {
                <div class="feed-item">
                    <div class="fdot" style="background:@(ls.TinhTrang == "Đã trả" ? "#2dd4a6" : "#f5a623")"></div>
                    <div>
                        <div class="ftxt"><strong>@ls.TenSach</strong> — @ls.TinhTrang</div>
                        <div class="ftime">@ls.MaPM · @ls.NgayTra</div>
                    </div>
                </div>
            }
        }
    </div>
</div>