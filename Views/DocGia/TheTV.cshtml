@model LibraryOS.Models.TheTV
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Thẻ thư viện";
    ViewData["ActiveMenu"] = "thethuvien";
}

@if (Model == null)
{
    <div class="panel full">
        <div class="empty"><div class="empty-icon">🪪</div>Không tìm thấy thông tin thẻ</div>
    </div>
}
else
{
    <div class="panel full">
        <div class="ph">
            <div><div class="pt">Thẻ thư viện của tôi</div><div class="ps">THETHUVIEN table</div></div>
            @if (Model.ConHan)
            {
                <span class="wc-valid">✓ Còn hiệu lực</span>
            }
            else
            {
                <span class="pill p-rose">✗ Hết hạn</span>
            }
        </div>

        <!-- Thông tin thẻ -->
        <div style="padding:24px 28px">
            <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:20px;margin-bottom:24px">
                @foreach (var item in new[] {
                        new { Label="Số thẻ",        Value=Model.SoTheTV,    Color="#f06292" },
                        new { Label="Họ tên",         Value=Model.HoTenDG,    Color="" },
                        new { Label="Giới tính",      Value=Model.GioiTinh,   Color="" },
                        new { Label="Ngày sinh",      Value=Model.NgaySinh,   Color="" },
                        new { Label="Ngày bắt đầu",   Value=Model.NgayBatDau, Color="" },
                        new { Label="Ngày hết hạn",   Value=Model.NgayHetHan, Color=Model.ConHan?"#2dd4a6":"#f06292" },
                        })
                {
                    <div style="background:var(--bg-raised);border:1px solid var(--border);
                                        border-radius:var(--r-md);padding:14px 16px">
                        <div style="font-size:10px;font-family:var(--mono);color:var(--txt-muted);
                                            text-transform:uppercase;letter-spacing:.06em;margin-bottom:6px">
                            @item.Label
                        </div>
                        <div style="font-size:14px;font-weight:500;font-family:var(--mono);
                                            color:@(item.Color != "" ? item.Color : "var(--txt-primary)")">
                            @(string.IsNullOrEmpty(item.Value) ? "—" : item.Value)
                        </div>
                    </div>
                }
            </div>

            <!-- Địa chỉ -->
            @if (!string.IsNullOrEmpty(Model.DiaChi))
            {
                <div style="background:var(--bg-raised);border:1px solid var(--border);
                                    border-radius:var(--r-md);padding:14px 16px;margin-bottom:16px">
                    <div style="font-size:10px;font-family:var(--mono);color:var(--txt-muted);
                                        text-transform:uppercase;letter-spacing:.06em;margin-bottom:6px">
                        Địa chỉ
                    </div>
                    <div style="font-size:13px;color:var(--txt-primary)">@Model.DiaChi</div>
                </div>
            }

            <!-- Trạng thái thẻ -->
            <div style="background:@(Model.ConHan ? "rgba(45,212,166,0.08)" : "rgba(240,98,146,0.08)");
                            border:1px solid @(Model.ConHan ? "rgba(45,212,166,0.2)" : "rgba(240,98,146,0.2)");
                            border-radius:var(--r-md);padding:16px 20px;
                            display:flex;align-items:center;justify-content:space-between">
                <div>
                    <div style="font-size:13px;font-weight:500;
                                    color:@(Model.ConHan ? "var(--accent-teal)" : "var(--accent-rose)")">
                        @(Model.ConHan ? "✓ Thẻ đang còn hiệu lực" : "✗ Thẻ đã hết hạn")
                    </div>
                    <div style="font-size:11px;font-family:var(--mono);color:var(--txt-muted);margin-top:4px">
                        Hết hạn: @Model.NgayHetHan
                    </div>
                </div>
                @if (Model.ConHan)
                {
                    <div style="text-align:right">
                        <div style="font-size:28px;font-weight:600;font-family:var(--mono);
                                            color:var(--accent-teal);line-height:1">
                            @Model.NgayConLai
                        </div>
                        <div style="font-size:11px;color:var(--txt-secondary)">ngày còn lại</div>
                    </div>
                }
            </div>
        </div>
    </div>
}